# --- API ---
PORT=3000
REDIS_URL=redis://redis:6379
# Comma-separated allowlist of web origins for CORS
CORS_ORIGIN=http://localhost:5173
# Default bucket config (per demo session)
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_PER_SEC=5

# --- Web (build-time) ---
# Browser talks to the API via the host-mapped port
NEXT_PUBLIC_API_URL=http://localhost:3000
